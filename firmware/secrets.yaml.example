# Copy this file to firmware/secrets.yaml and fill in real values before compiling.
# firmware/secrets.yaml is git-ignored — never commit the file with real credentials.

# WiFi credentials
wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# ESPHome API encryption key — must be a base64-encoded 32-byte value.
# Generate with: python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
api_encryption_key: "REPLACE_WITH_BASE64_32_BYTES"

# OTA update password
ota_password: "REPLACE_WITH_STRONG_PASSWORD"

# Fallback hotspot password (shown when the device cannot reach your WiFi)
fallback_ap_password: "REPLACE_WITH_STRONG_PASSWORD"

# Built-in ESPHome web UI credentials
web_username: admin
web_password: "REPLACE_WITH_STRONG_PASSWORD"
